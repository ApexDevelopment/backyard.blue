# Environment Configuration for Backyard
# Copy this file to .env and fill in the values

# ===================
# Application
# ===================
# The public URL where this application is hosted
INSTANCE_URL=http://localhost:3000
# Secret key for encrypting session cookies (generate a random 32+ char string)
SESSION_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ===================
# PostgreSQL
# ===================
DATABASE_URL=postgresql://backyard:backyard@localhost:5432/backyard

# ===================
# AT Protocol OAuth
# ===================
# Private keys for OAuth client authentication (ES256 / P-256 JWK format)
# Generate with: node -e "const{generateKeyPairSync}=require('node:crypto');const{publicKey,privateKey}=generateKeyPairSync('ec',{namedCurve:'P-256'});const j=privateKey.export({format:'jwk'});j.alg='ES256';j.use='sig';console.log(JSON.stringify(j))"
OAUTH_PRIVATE_KEY_1=
# Optional additional keys for key rotation
OAUTH_PRIVATE_KEY_2=
OAUTH_PRIVATE_KEY_3=

# ===================
# Firehose (Jetstream)
# ===================
# Custom Jetstream URL (leave empty to use the default public instance)
# Default: wss://jetstream2.us-east.bsky.network/subscribe
JETSTREAM_URL=
# Set to "true" to disable firehose consumption entirely
FIREHOSE_DISABLED=

# ===================
# Signup Gating
# ===================
# Controls who can create a new session on this instance.
# "open"      — anyone can sign in (default)
# "allowlist" — only DIDs/handles in the signup_allowlist table
# "closed"    — no new signups; only returning users can sign in
SIGNUP_MODE=open
# DID of the instance admin (required for /api/admin/* endpoints)
# Example: did:plc:abc123...
ADMIN_DID=
