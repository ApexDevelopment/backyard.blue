# Environment Configuration for Backyard
# Copy this file to .env and fill in the values

# ===================
# Application
# ===================
# The public URL where this application is hosted
INSTANCE_URL=http://127.0.0.1:3000
# Secret key for encrypting session cookies (generate a random 32+ char string)
SESSION_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Maximum request body size for uploads (default: 512K, which is too small for
# GIFs and videos).
# Consumed by SvelteKit adapter-node.
BODY_SIZE_LIMIT=104857600

# Filesystem path where the app will cache fetched blobs (avatars, banners, post media).
# Use an absolute path when running in Docker (e.g. /data/blob-cache) so it can be mounted
# to a named volume. If unset, defaults to ./blob-cache relative to the app working dir.
BLOB_CACHE_DIR=

# Maximum total size for the on-disk blob cache in bytes. When the cache
# would exceed this size, older entries are evicted until the size fits.
# Defaults to 2147483648 (2 GiB) when unset.
BLOB_CACHE_MAX_BYTES=2147483648

# Redis connection URL for the primary blob cache tier. When set, blobs are
# cached in Redis first and evicted to disk (LRU) when the Redis cache
# exceeds BLOB_REDIS_MAX_BYTES. When unset, blobs are cached on disk only.
REDIS_URL=

# Maximum total size of the Redis blob cache in bytes. When the cache
# would exceed this size, least-recently-used entries are evicted to disk.
# Defaults to 536870912 (512 MiB) when unset.
BLOB_REDIS_MAX_BYTES=536870912

# ===================
# PostgreSQL
# ===================
DATABASE_URL=postgresql://backyard:backyard@db:5432/backyard

# ===================
# AT Protocol OAuth
# ===================
# Private keys for OAuth client authentication (ES256 / P-256 JWK format)
# Generate with: node -e "const{generateKeyPairSync}=require('node:crypto');const{publicKey,privateKey}=generateKeyPairSync('ec',{namedCurve:'P-256'});const j=privateKey.export({format:'jwk'});j.alg='ES256';j.use='sig';console.log(JSON.stringify(j))"
OAUTH_PRIVATE_KEY_1=
# Optional additional keys for key rotation
OAUTH_PRIVATE_KEY_2=
OAUTH_PRIVATE_KEY_3=

# ===================
# Jetstream
# ===================
# Custom Jetstream URL (leave empty to use the default public instance)
# Default: wss://jetstream2.us-east.bsky.network/subscribe
JETSTREAM_URL=
# Set to "true" to disable Jetstream consumption entirely
# NOT RECOMMENDED except for testing, this prevents the app from receiving live data.
JETSTREAM_DISABLED=

# ===================
# Rainbow
# ===================
# URL of a service exposing com.atproto.sync.listReposByCollection,
# used at startup to discover all repos with Backyard records.
# Can be Rainbow (https://github.com/bluesky-social/indigo/tree/main/cmd/rainbow)
# or any compatible implementation.
# Default: https://bsky.network
RAINBOW_URL=

# ===================
# Signup Gating
# ===================
# Controls who can create a new session on this instance.
# "open"      — anyone can sign in (default)
# "allowlist" — only DIDs/handles in the signup_allowlist table
SIGNUP_MODE=open
# Comma-separated DIDs of instance admins (required for /api/admin/* endpoints)
# Example: did:plc:abc123...,did:plc:def456...
# CAUTION! Admins have full access to all admin API endpoints!
# More robust moderation tools will come in the future.
ADMIN_DIDS=

# ===================
# Captcha
# ===================
# Comma-separated list of PDS hostnames where captcha signup is supported.
# PDSes using PDS Gatekeeper that are not in this list will show a fallback
# message directing users to sign up via Bluesky instead.
# Example: my-pds.example.com,another-pds.example.com
CAPTCHA_PDS_ALLOWLIST=

# ===================
# Identity Resolution
# ===================
# XRPC-compatible endpoint for resolving handles to DIDs.
# Falls back to https://public.api.bsky.app if unset.
# A good choice: https://slingshot.microcosm.blue/
HANDLE_RESOLVER_URL=

# ===================
# News Panel
# ===================
# DID of the account whose posts populate the news panel (optional).
# If unset, resolves NEWS_HANDLE via the handle resolver.
NEWS_DID=
# Handle of the news account (defaults to backyard.blue if unset)
NEWS_HANDLE=

# ===================
# Legal Pages
# ===================
# Paths to plaintext or markdown files rendered at /terms_of_service and
# /community_guidelines. If set, users must agree before signing in and
# links appear in the site footer.
TOS_PATH=
COMMUNITY_GUIDELINES_PATH=
