{
  "lexicon": 1,
  "id": "blue.backyard.actor.profile",
  "description": "A declaration of a Backyard account profile.",
  "defs": {
    "main": {
      "type": "record",
      "description": "A declaration of a Backyard account profile.",
      "key": "literal:self",
      "record": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "maxGraphemes": 64,
            "maxLength": 640,
            "description": "Display name for the user."
          },
          "pronouns": {
            "type": "string",
            "maxGraphemes": 64,
            "maxLength": 640,
            "description": "User's preferred pronouns."
          },
          "description": {
            "type": "string",
            "maxGraphemes": 256,
            "maxLength": 2560,
            "description": "Free-form profile description text (bio)."
          },
          "avatar": {
            "type": "blob",
            "accept": ["image/png", "image/jpeg"],
            "maxSize": 1000000,
            "description": "Small avatar image for the user."
          },
          "banner": {
            "type": "blob",
            "accept": ["image/png", "image/jpeg"],
            "maxSize": 1000000,
            "description": "Larger horizontal banner image."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "When the profile was initially created."
          }
        }
      }
    }
  }
}
